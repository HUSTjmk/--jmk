t = a.MakeSketchTransform(sketchPlane=f1[1], sketchPlaneSide=SIDE1, origin=(
    3.631282, 9.920621, 0.0))
s = mdb.models['assembly-improved'].ConstrainedSketch(name='__profile__', 
    sheetSize=18.05, gridSpacing=0.45, transform=t)
g, v, d, c = s.geometry, s.vertices, s.dimensions, s.constraints
s.setPrimaryObject(option=SUPERIMPOSE)
a = mdb.models['assembly-improved'].rootAssembly
a.projectReferencesOntoSketch(sketch=s, filter=COPLANAR_EDGES)
