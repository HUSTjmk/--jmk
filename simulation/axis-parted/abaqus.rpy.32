    1.34274025436025))
s.PerpendicularConstraint(entity1=g[11], entity2=g[44], addUndoState=False)
s.CoincidentConstraint(entity1=v[29], entity2=g[11], addUndoState=False)
s.Line(point1=(-3.46350171634685, 1.34274025436025), point2=(-3.63128200005198, 
    1.34274025441846))
s.HorizontalConstraint(entity=g[45], addUndoState=False)
s.CoincidentConstraint(entity1=v[31], entity2=g[6], addUndoState=False)
a = mdb.models['assembly-improved'].rootAssembly
f1 = a.instances['cornea-1'].faces
pickedFaces = f1.getSequenceFromMask(mask=('[#2 ]', ), )
a.PartitionFaceBySketch(faces=pickedFaces, sketch=s)
s.unsetPrimaryObject()
